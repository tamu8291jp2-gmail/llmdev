     "text": [
      "はじめまして、 山田太郎  と申します。\n",
      "年齢は  25  歳です。来年は  26  歳になります。\n",
      "よろしくお願いします。\n"
     ]
    }
   ],
   "source": [
    "# 名前を変数として定義\n",
    "name = \"山田太郎\"\n",
    "\n",
    "# 年齢を変数として定義\n",
    "age = 25\n",
    "\n",
    "# 来年の年齢を変数として定義\n",
    "age_next = age + 1\n",
    "\n",
    "# 結果を表示\n",
    "print(\"はじめまして、\", name, \" と申します。\")\n",
    "print(\"年齢は \", age, \" 歳です。来年は \", age_next, \" 歳になります。\")\n",
    "print(\"よろしくお願いします。\")"
   ]
  }
 ],
