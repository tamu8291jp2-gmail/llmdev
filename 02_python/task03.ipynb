   "source": [
    "# 10年後の金額を複利で予測するプログラムを作成しよう\n",
    "principal = int(input(\"元金を入力してください: \"))\n",
    "annual_rate = float(input(\"年利を入力してください:\"))\n",
    "year = 0\n",
    "total_amount = principal\n",
    "\n",
    "for year in range(10):\n",
    "    total_amount = total_amount * (1 + (annual_rate / 100))\n",
    "\n",
    "print(f\"10年後の金額: {total_amount:.2f}\")"
   ]
  }
